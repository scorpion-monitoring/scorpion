{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Maturity Model Schema",
	"description": "Schema for a maturity model object",
	"type": "object",
	"properties": {
		"general": {
			"type": "object",
			"properties": {
				"siteName": {
					"type": "string"
				},
				"locale": {
					"type": "string"
				},
				"analytics": {
					"type": "boolean"
				}
			}
		},
		"maturityModel": {
			"type": "object",
			"properties": {
				"enabled": {
					"type": "boolean"
				},
				"postProcessing": {
					"type": "string"
				},
				"postProcessingUrl": {
					"type": "string"
				},
				"postProcessingEmail": {
					"type": "string"
				},
				"postProcessingTicketTemplate": {
					"type": "string"
				},
				"additionalFields": {
					"type": "array",
					"items": {
						"type": "string"
					}
				}
			}
		},
		"security": {
			"type": "object",
			"properties": {
				"oidcProviders": {
					"type": "array",
					"items": {
						"type": "object",
						"properties": {
							"name": {
								"type": "string"
							},
							"issuer": {
								"type": "string"
							},
							"clientId": {
								"type": "string"
							},
							"enabled": {
								"type": "boolean"
							}
						}
					}
				},
				"sessionTimeout": {
					"type": "number"
				},
				"userSignup": {
					"type": "string",
					"enum": ["open", "invite-only", "closed"]
				}
			}
		},
		"notifications": {
			"type": "object",
			"properties": {
				"smtpHost": {
					"type": "string"
				},
				"smtpPort": {
					"type": "number"
				},
				"smtpUser": {
					"type": "string"
				},
				"smtpPass": {
					"type": "string"
				},
				"smtpFrom": {
					"type": "string"
				},
				"smtpTls": {
					"type": "boolean"
				}
			}
		},
		"integrations": {
			"type": "object",
			"properties": {
				"jira": {
					"type": "object",
					"properties": {
						"enabled": {
							"type": "boolean"
						},
						"url": {
							"type": "string"
						},
						"username": {
							"type": "string"
						},
						"apiToken": {
							"type": "string"
						}
					}
				}
			}
		},
		"advanced": {
			"type": "object",
			"properties": {
				"apiEnabled": {
					"type": "boolean"
				},
				"apiDefaultPageSize": {
					"type": "number"
				},
				"apiRateLimit": {
					"type": "number"
				},
				"apiCors": {
					"type": "array",
					"items": {
						"type": "string"
					}
				}
			}
		}
	},
	"required": ["topic"],
	"additionalProperties": false
}
