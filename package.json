		"dataframe-js": "^1.4.4",
		"graphology": "^0.26.0",
		"jose": "^6.1.3",
		"marked": "^17.0.1",
		"node-schedule": "^2.1.1",
		"nodemailer": "^8.0.2",
		"pdf-lib": "^1.17.1",
		"plotly.js-dist": "^3.3.1",
		"postgres": "^3.4.7",
		"sigma": "^3.0.2",
		"swagger-ui-dist": "^5.31.0"
	}
