# Replace with your project info
PUBLIC_GITHUB_REPO="https://example.org"
PUBLIC_DOCS_URL="https://example.org"
PUBLIC_CONTACT_EMAIL="info@example.org"
PUBLIC_IMPRINT_URL="https://example.org/imprint/"

# Replace with your DB credentials
DATABASE_URL="postgres://root:replace_with_strong_password@localhost:5432/local"
# Leave empty for not path prefix
BASE_PATH=/test
# Public app origin used by SvelteKit for CSRF same-origin checks
ORIGIN="http://localhost"
# Tell adapter-node which reverse-proxy headers carry the public URL
PROTOCOL_HEADER="x-forwarded-proto"
HOST_HEADER="x-forwarded-host"
PORT_HEADER="x-forwarded-port"
XFF_DEPTH="1"
# Replace with your JWT secret key
JWT_SECRET="replace_with_long_random_jwt_secret"
# Replace with your OpenAlex API key
OPENALEX_API_KEY="your_openalex_api_key_here"

# Replace with your RSA key paths for backup encryption
BACKUP_RSA_PRIVATE_KEY_PATH="./keys/rsa-private-key.pem"
BACKUP_RSA_PUBLIC_KEY_PATH="./keys/rsa-public-key.pem"