[
    {
        "title": "Please provide basic information about your service.",
        "fields": [
            {
                "label": "Service Icon",
                "type": "image",
                "mapping": {
                    "jsonPath": "icon"
                }
            },
            {
                "label": "Service Slug",
                "type": "text",
                "mapping": {
                    "jsonPath": "shortName"
                }
            },
            {
                "label": "Service Name",
                "type": "text",
                "mapping": {
                    "jsonPath": "name"
                }
            },
            {
                "label": "Service License",
                "type": "license",
                "mapping": {
                    "jsonPath": "license"
                }
            },
            {
                "label": "Lifecycle Stage",
                "type": "select",
                "mapping": {
                    "jsonPath": "metadata.stage",
                    "options": [
                        { "value": "DEV", "label": "Development" },
                        { "value": "DEMO", "label": "Demonstrator" },
                        { "value": "PROD", "label": "Production" }
                    ]
                }
            }
        ]
    },
    {
        "title": "Please provide information about the service provision.",
        "fields": [
            {
                "label": "Service Provider",
                "type": "provider",
                "mapping": {
                    "jsonPath": "provider"
                }
            },
            {
                "label": "Service Center",
                "type": "multi-select",
                "mapping": {
                    "jsonPath": "consortia",
                    "config": {
                        "endpoint": "/api/consortia"
                    }
                }
            }
        ]
    },
    {
        "title": "Please configure a KPI set for your service.",
        "component": "kpi-set",
        "jsonPath": "."
    }
]